---
import fs from "node:fs";
import path from "node:path";
import { renderMarkdown } from "../lib/renderMarkdown.js";
import "../styles/global.css";

const markdownPath = path.join(process.cwd(), "Текстовый документ.md");
const biographyMarkdown = fs.readFileSync(markdownPath, "utf8");
const biographyHtml = renderMarkdown(biographyMarkdown);
---

<!doctype html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Toàn bộ tiểu sử Nguyễn Thị Lan để đọc lại từ đầu đến cuối trước buổi phỏng vấn."
    />
    <title>Toàn bộ tiểu sử Nguyễn Thị Lan</title>
  </head>
  <body>
    <main class="reader-shell">
      <header class="reader-header">
        <a class="reader-back" href="/">← Quay lại trang mốc thời gian</a>
        <p class="reader-eyebrow">Bản đọc đầy đủ</p>
        <h1>Toàn bộ tiểu sử Nguyễn Thị Lan</h1>
        <p>
          Trang này lấy nội dung trực tiếp từ file nguồn <strong>Текстовый документ.md</strong>.
          Dùng để đọc liền mạch từ đầu đến cuối trước khi ôn câu hỏi chi tiết.
        </p>
      </header>

      <article class="biography-reader" set:html={biographyHtml} />
    </main>
  </body>
</html>

<style>
  .reader-shell {
    width: min(1040px, calc(100% - 28px));
    margin: 0 auto;
    padding: 28px 0 56px;
  }

  .reader-header,
  .biography-reader {
    border: 1px solid #d8ded8;
    background: rgba(255, 255, 255, 0.94);
  }

  .reader-header {
    padding: 28px;
  }

  .reader-back {
    display: inline-flex;
    align-items: center;
    min-height: 40px;
    border: 1px solid #b9c4bc;
    border-radius: 6px;
    padding: 0 14px;
    background: #ffffff;
    color: #121816;
    font-weight: 800;
    text-decoration: none;
  }

  .reader-back:focus-visible {
    outline: 3px solid #135fbc;
    outline-offset: 3px;
  }

  .reader-eyebrow {
    margin: 28px 0 8px;
    color: #5a665f;
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .reader-header h1 {
    max-width: 820px;
    margin: 0;
    font-size: clamp(2rem, 5vw, 4rem);
    line-height: 1;
  }

  .reader-header p:last-child {
    max-width: 760px;
    margin: 18px 0 0;
    color: #26352f;
    font-size: 1.04rem;
    line-height: 1.65;
  }

  .biography-reader {
    margin-top: 18px;
    padding: 30px;
    color: #121816;
  }

  .biography-reader :global(h2),
  .biography-reader :global(h3),
  .biography-reader :global(h4),
  .biography-reader :global(h5),
  .biography-reader :global(h6) {
    max-width: 900px;
    margin: 34px 0 14px;
    color: #111715;
    line-height: 1.18;
    letter-spacing: 0;
  }

  .biography-reader :global(h2) {
    font-size: clamp(1.7rem, 3vw, 2.5rem);
  }

  .biography-reader :global(h3) {
    border-top: 3px solid #121816;
    padding-top: 18px;
    font-size: clamp(1.35rem, 2.5vw, 1.85rem);
  }

  .biography-reader :global(h4),
  .biography-reader :global(h5),
  .biography-reader :global(h6) {
    font-size: 1.08rem;
    text-transform: uppercase;
  }

  .biography-reader :global(p),
  .biography-reader :global(li),
  .biography-reader :global(blockquote) {
    max-width: 900px;
    font-size: 1rem;
    line-height: 1.75;
  }

  .biography-reader :global(p) {
    margin: 12px 0;
  }

  .biography-reader :global(ul),
  .biography-reader :global(ol) {
    max-width: 900px;
    margin: 12px 0 18px;
    padding-left: 26px;
  }

  .biography-reader :global(li + li) {
    margin-top: 8px;
  }

  .biography-reader :global(blockquote) {
    margin: 18px 0;
    border-left: 4px solid #d49a16;
    padding: 12px 18px;
    background: #fff9eb;
    font-weight: 700;
  }

  .biography-reader :global(hr) {
    max-width: 900px;
    height: 1px;
    margin: 28px 0;
    border: 0;
    background: #d8ded8;
  }

  .biography-reader :global(code) {
    border: 1px solid #d8ded8;
    border-radius: 4px;
    padding: 0 5px;
    background: #f2f5f1;
  }

  .biography-reader :global(.table-scroll) {
    max-width: 100%;
    overflow-x: auto;
  }

  .biography-reader :global(table) {
    width: 100%;
    min-width: 640px;
    margin: 18px 0;
    border-collapse: collapse;
    font-size: 0.95rem;
  }

  .biography-reader :global(th),
  .biography-reader :global(td) {
    border: 1px solid #cbd4cc;
    padding: 10px 12px;
    text-align: left;
    vertical-align: top;
  }

  .biography-reader :global(th) {
    background: #edf3ef;
    font-weight: 900;
  }

  @media (max-width: 720px) {
    .reader-shell {
      width: min(100% - 18px, 1040px);
      padding-top: 10px;
    }

    .reader-header,
    .biography-reader {
      padding: 18px;
    }
  }
</style>
