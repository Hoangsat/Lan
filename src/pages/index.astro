---
import BiographyDetective from "../components/BiographyDetective.svelte";
import biography from "../data/biography.json";
import "../styles/global.css";
---

<!doctype html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Trang chuẩn bị lời khai phỏng vấn cho Nguyễn Thị Lan, giúp đọc lại hành trình, nguyên nhân, hệ quả và bối cảnh theo từng giai đoạn."
    />
    <title>Chuẩn bị phỏng vấn của Nguyễn Thị Lan</title>
  </head>
  <body>
    <BiographyDetective
      client:load
      person={biography.person}
      events={biography.events}
      filters={biography.filters}
      stages={biography.stages}
      interviewNotes={biography.interviewNotes}
    />
  </body>
</html>
